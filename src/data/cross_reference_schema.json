{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hidden Equations Cross-Reference Map",
  "description": "Schema for symbolic design relationships between formula cards, compare pairs, graph edges, and learning paths.",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "relationshipTypes", "edges", "learningPaths"],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "version", "boundary"],
      "properties": {
        "title": { "type": "string", "minLength": 3 },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "boundary": { "type": "string", "minLength": 10 }
      }
    },
    "relationshipTypes": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 3 },
      "required": [
        "mirror",
        "buffer",
        "amplifier",
        "repair_path",
        "contrast",
        "sequence",
        "family_bridge",
        "example_pair"
      ]
    },
    "edges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source",
          "target",
          "relationship",
          "label",
          "strength",
          "recommendedForCompare"
        ],
        "properties": {
          "source": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$",
            "description": "Source formula card ID."
          },
          "target": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$",
            "description": "Target formula card ID."
          },
          "relationship": {
            "type": "string",
            "enum": [
              "mirror",
              "buffer",
              "amplifier",
              "repair_path",
              "contrast",
              "sequence",
              "family_bridge",
              "example_pair"
            ]
          },
          "label": {
            "type": "string",
            "minLength": 10,
            "description": "Plain-language explanation of the symbolic connection."
          },
          "strength": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "recommendedForCompare": {
            "type": "boolean"
          },
          "boundaryNote": {
            "type": "string"
          }
        }
      }
    },
    "learningPaths": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "description", "formulaIds", "boundaryNote"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "title": {
            "type": "string",
            "minLength": 3
          },
          "description": {
            "type": "string",
            "minLength": 10
          },
          "formulaIds": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9_]+$"
            },
            "uniqueItems": true
          },
          "boundaryNote": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    }
  }
}
